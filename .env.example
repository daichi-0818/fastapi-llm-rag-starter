# LLM provider selection: "anthropic" or "google"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Google (Gemini) — required if LLM_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Embeddings provider: "google" (text-embedding-004) or "fake" (deterministic, no API)
EMBEDDINGS_PROVIDER=google
EMBEDDINGS_MODEL=text-embedding-004

# Vector store
CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION=documents

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
